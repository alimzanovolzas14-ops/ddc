# /etc/ddc-portal.env — настройки сервера портала.
# Скопируйте в /etc/ddc-portal.env и заполните значения.
# Файл читает systemd (см. ddc-portal.service). НЕ коммитьте его в git.

# Порт, который слушает Node (Nginx проксирует на него). Наружу не открывается.
PORT=3000

# Слушать только локально — снаружи доступ идёт только через Nginx (HTTPS).
HOST=127.0.0.1

# Подключение к PostgreSQL. Пароль замените на свой (см. DEPLOY.md, шаг 3).
DATABASE_URL=postgres://ddc:ЗАМЕНИТЕ_ПАРОЛЬ@localhost:5432/ddc

# Секрет для подписи токенов входа. ОБЯЗАТЕЛЬНО замените на длинную случайную
# строку:  openssl rand -hex 32
DDC_SECRET=ЗАМЕНИТЕ_НА_openssl_rand_hex_32

# Папка со статическим сайтом (его раздаёт этот же сервер).
SITE_DIR=/opt/ddc-portal/DDC_site
